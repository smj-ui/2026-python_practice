<script>
"use strict";

// ══════════════════════════════════════════
// ⚙️  CONFIG
// ══════════════════════════════════════════
const FORM_URL     = 'https://docs.google.com/forms/d/e/1FAIpQLSfDzd4M17HFoX1Kr4qr65DICx6uQXiKQKNoEIRv3h9NUMV_bA/formResponse';
const E_CLASS      = 'entry.1342927365';
