    required: ['for','range','print']
  },
  p2: {
    expected: NESTED_30,
    required: ['for','for','range','print']
  },
  p3: {
    expected: '##\n##\n##\n##',
    required: ['for','for','print','end']
  },
  p4: {
    expected: '1\n2\n★\n4\n★',
    required: ['for','if','else']
  },
  p5: {
    expected: '1 2 3 \n★ 2 3 \n1 2 3 ',
    required: ['for','for','if','else']
  },
  hw: {
    expected: 'A A A A \nA A A A \nA A A A \n1 * 3 \n1 * 3 \n1 * 3 \n1 2 3 \n- - - \n1 2 3 ',
    required: ['for','if','else']
  }
};

const STARTER = {
  ex1: `for classroom in range(1, 11):\n    print(f"1학년 {classroom}반")`,
  ex3: `for i in range(3):\n    for j in range(4):\n        print("*", end="")\n    print()`,
  ex4: `for num in range(1, 6):\n    if num % 2 == 0:\n        print("짝수")\n    else:\n        print(num)`,
  ex5: `for i in range(1, 4):\n    for j in range(1, 4):\n        if i == 2 and j == 2:\n            print("●", end=" ")\n        else:\n            print(j, end=" ")\n    print()`
};

// ══════════════════════════════════════════
// 🔒  SECURITY
// ══════════════════════════════════════════
const BANNED = [
  {re:/import\s+os\b/,       msg:'os 모듈은 사용 불가'},
  {re:/import\s+sys\b/,      msg:'sys 모듈은 사용 불가'},
  {re:/import\s+subprocess/, msg:'subprocess 모듈은 사용 불가'},
  {re:/import\s+socket/,     msg:'socket 모듈은 사용 불가'},
  {re:/import\s+requests/,   msg:'requests 모듈은 사용 불가'},
  {re:/open\s*\(/,           msg:'파일 열기(open)는 사용 불가'},
  {re:/__import__/,          msg:'__import__ 사용 불가'},
  {re:/\beval\s*\(/,         msg:'eval() 사용 불가'},
  {re:/\bexec\s*\(/,         msg:'exec() 사용 불가'},
];

function secCheck(code) {
  if (!code.trim()) return '코드를 먼저 작성하세요.';
  if (code.length > MAX_CODE) return `코드가 너무 깁니다 (최대 ${MAX_CODE}자, 현재 ${code.length}자)`;
  for (const {re,msg} of BANNED) if (re.test(code)) return '🔒 보안 차단: ' + msg;
  if (/while\s+(True|1)\s*:/.test(code) && !/break|return/.test(code))
    return '무한루프 감지: while True: 와 함께 break 또는 return을 쓰세요.';
  return null;
}

// ══════════════════════════════════════════
// 🐍  PYTHON EXEC
// ══════════════════════════════════════════
function skRead(x) {
  if (Sk.builtinFiles?.files?.[x] === undefined) throw 'File not found: ' + x;
  return Sk.builtinFiles.files[x];
}

async function pyRun(code) {
  const err = secCheck(code);
  if (err) return {ok:false, out:'', err};
  let stdout='', truncated=false;
  Sk.configure({
    output: t => {
      stdout += t;
      if (stdout.length > MAX_OUT) { truncated=true; throw new Error('출력이 너무 많습니다. 무한루프를 확인하세요.'); }
    },
    read: skRead,
    inputfun: () => Promise.resolve(''),
    inputfunTakesPrompt: true,
    __future__: Sk.python3,
    execLimit: EXEC_TIMEOUT
  });
  const run = Sk.misceval.asyncToPromise(() => Sk.importMainWithBody('<stdin>', false, code, true));
  const timeout = new Promise((_,rej) => setTimeout(() => rej(new Error(`실행 시간 초과 (${EXEC_TIMEOUT/1000}초)`)), EXEC_TIMEOUT));
  try {
    await Promise.race([run, timeout]);
    const out = stdout.replace(/\n$/, '');
    return {ok:true, out: truncated ? out+'\n[출력 잘림]' : out};
  } catch(e) {
    return {ok:false, out:stdout.replace(/\n$/,''), err:String(e)};
  }
}

function norm(s) {
  return (s||'').replace(/\r\n/g,'\n').replace(/\r/g,'\n').trim();
}
// 후행 공백 제거 후 비교 (격자 출력 trailing space 허용)
function normGrid(s) {
  return (s||'').replace(/\r\n/g,'\n').replace(/\r/g,'\n')
    .split('\n').map(l=>l.trimEnd()).join('\n').trim();
}

// ══════════════════════════════════════════
// 📊  STATE
// ══════════════════════════════════════════
const results   = {};
const runCounts = {};
let lastSubmit  = 0;
let submitting  = false;

// ══════════════════════════════════════════
// 🔢  EXEC COUNT
// ══════════════════════════════════════════
function setCount(id, state) {
  const el = document.getElementById('cnt-'+id);
  if (!el) return;
  if (state === 'run') { el.textContent = '[*]'; return; }
  runCounts[id] = (runCounts[id]||0)+1;
  el.textContent = '['+runCounts[id]+']';
}

// ══════════════════════════════════════════
// ▶  RUN
// ══════════════════════════════════════════
async function runCell(id) {
  const ed  = document.getElementById('ed-'+id);
  const btn = document.querySelector('#cell-'+id+' .cell-run');
  if (!ed) return;
  if (btn) { btn.classList.add('running'); btn.disabled=true; }
  setCount(id, 'run');
  const res = await pyRun(ed.value);
  if (btn) { btn.classList.remove('running'); btn.disabled=false; }
  setCount(id, 'done');
  showOutput(id, res.ok ? 'info' : 'fail',
    res.ok ? '▶ 실행 결과' : '⚠ 오류 발생',
    res.ok ? (res.out||'(출력 없음)') : ((res.out?res.out+'\n\n':'')+res.err));
}

// ══════════════════════════════════════════
// ✓  CHECK
// ══════════════════════════════════════════
async function checkCell(id) {
  const ed  = document.getElementById('ed-'+id);
  const cfg = CELL_CFG[id];
  if (!ed || !cfg) return;
  const code = ed.value.trim();

  // 키워드 검사
  for (const kw of cfg.required) {
    // for 키워드 중복 허용을 위해 개수 체크
    if (kw === 'for' && id === 'p2') {
      const cnt = (code.match(/\bfor\b/g)||[]).length;
      if (cnt < 2) {
        showOutput(id,'fail','✗ 오답','중첩 반복문을 위해 for 문이 2개 이상 필요합니다.');
        results[id]='오답'; updateProgress(); return;
      }
      continue;
    }
    if (!code.includes(kw)) {
      showOutput(id,'fail',`✗ 오답 — '${kw}'가 없습니다`,`필수 구문 '${kw}'이(가) 코드에 없습니다.\n배운 문법을 직접 활용해야 합니다.`);
      results[id]='오답'; updateProgress(); return;
    }
  }

  showOutput(id,'info','⏳ 채점 중...','');
  const res = await pyRun(code);
  setCount(id,'done');

  if (!res.ok) {
    showOutput(id,'fail','✗ 오류 — 먼저 오류를 고치세요', res.err);
    results[id]='오답'; updateProgress(); return;
  }

  const actual   = normGrid(res.out);
  const expected = normGrid(cfg.expected);

  if (actual === expected || actual.includes(expected)) {
    showOutput(id,'pass','✓ 정답! 🎉', res.out);
    results[id]='정답';
  } else {
    const el = expected.split('\n'), al = actual.split('\n');
    let fb = `실행 결과\n${res.out||'(없음)'}\n\n줄별 비교\n`;
    for (let i=0; i<Math.max(el.length,al.length); i++) {
      const e=el[i]??'(없음)', a=al[i]??'(없음)';
      fb += e===a ? `  ${i+1}번째 줄: ✓\n` : `  ${i+1}번째 줄: ✗\n    정답: "${e}"\n    작성: "${a}"\n`;
    }
    showOutput(id,'fail','✗ 오답 — 출력을 다시 확인하세요', fb);
    results[id]='오답';
  }
  updateProgress();
}

// ══════════════════════════════════════════
// ↺  RESET
// ══════════════════════════════════════════
function resetCell(id) {
  const ed = document.getElementById('ed-'+id);
  if (ed) ed.value = STARTER[id]||'';
  document.getElementById('out-'+id)?.classList.remove('show');
  const cnt = document.getElementById('cnt-'+id);
  if (cnt) cnt.textContent='[ ]';
  delete runCounts[id]; delete results[id];
  updateProgress();
}

// ══════════════════════════════════════════
// 🖥  OUTPUT HELPER
// ══════════════════════════════════════════
function showOutput(id, type, bar, text) {
  const outEl  = document.getElementById('out-'+id);
  const barEl  = document.getElementById('outbar-'+id);
  const txtEl  = document.getElementById('outtxt-'+id);
  if (!outEl) return;
  outEl.classList.add('show');
  barEl.className = 'out-bar '+type;
  barEl.textContent = bar;
  txtEl.textContent = text;
}

// ══════════════════════════════════════════
// 📊  PROGRESS
// ══════════════════════════════════════════
function updateProgress() {
  const passed = PRACTICE_IDS.filter(id=>results[id]==='정답').length;
  const total  = PRACTICE_IDS.length;
  const pct    = Math.round(passed/total*100);
  document.getElementById('progFill').style.width = pct+'%';
  document.getElementById('progCount').textContent = `${passed} / ${total} 완료`;

  // 과제 체크리스트
  const hwItem = document.getElementById('hwCheckItem');
  if (hwItem) {
    if (results[HW_ID]==='정답') {
      hwItem.textContent='✅ 과제(🏁) 정답 확인 완료';
      hwItem.style.color='var(--accent-green)';
      hwItem.style.fontWeight='700';
      document.getElementById('submitCard').style.borderColor='var(--accent-green)';
    } else {
      hwItem.textContent='⬜ 과제(🏁) 정답 확인 완료';
      hwItem.style.color='var(--text-secondary)';
      hwItem.style.fontWeight='normal';
      document.getElementById('submitCard').style.borderColor='var(--accent-blue)';
    }
  }
}

