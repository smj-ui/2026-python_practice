// 채점 대상 셀 목록
const PRACTICE_IDS = ['p1','p2','p3','p4','p5','hw'];
const HW_ID        = 'hw';

// 정답 설정
const GRADE_10 = Array.from({length:10},(_,i)=>`${i+1}학년 1반\n${Array.from({length:9},(_,j)=>`${i+1}학년 ${j+2}반`).join('\n')}`).join('\n');
// 실제 expected 값
const NESTED_30 = Array.from({length:3},(_,g)=>Array.from({length:10},(_,c)=>`${g+1}학년 ${c+1}반`).join('\n')).join('\n');

const CELL_CFG = {
