<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>개념8 - 중첩 반복문 | Python 실습 노트북</title>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+KR:wght@400;500;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #f0f2f5;
      --surface: #ffffff;
      --surface2: #f0f2f5;
      --border: #dde1e7;
      --border-focus: #0f62fe;
      --text: #161616;
      --text-secondary: #525252;
      --text-tertiary: #8d8d8d;
      --accent-blue: #0f62fe;
      --accent-green: #198038;
      --accent-orange: #ff832b;
      --accent-red: #da1e28;
      --accent-teal: #007d79;
      --tag-ex-bg: #d0e2ff;
      --tag-ex-text: #0043ce;
      --tag-pr-bg: #defbe6;
      --tag-pr-text: #0e6027;
      --tag-hw-bg: #ffd6e8;
      --tag-hw-text: #9f1853;
      --tag-concept-bg: #e8daff;
      --tag-concept-text: #6929c4;
      --editor-bg: #161616;
      --editor-text: #f4f4f4;
      --out-pass-bg: #defbe6;
      --out-pass-text: #198038;
      --out-fail-bg: #fff1f1;
      --out-fail-text: #da1e28;
      --out-info-bg: #edf5ff;
      --out-info-text: #0043ce;
      --shadow-sm: 0 1px 2px rgba(0,0,0,0.08);
      --shadow-md: 0 2px 6px rgba(0,0,0,0.12);
      --header-h: 56px;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'IBM Plex Sans KR', 'Noto Sans KR', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      font-size: 15px;
    }

    /* ── HEADER ── */
    .nb-header {
      position: sticky; top: 0; z-index: 200;
      height: var(--header-h);
      background: var(--text);
      display: flex; align-items: center; gap: 0;
      box-shadow: 0 2px 8px rgba(0,0,0,0.3);
    }
    .nb-logo {
      display: flex; align-items: center; gap: 10px;
      padding: 0 20px; height: 100%;
      border-right: 1px solid #393939;
    }
    .nb-logo svg { width: 26px; height: 26px; }
    .nb-title-area { padding: 0 20px; flex: 1; }
    .nb-title { font-size: 15px; font-weight: 600; color: #f4f4f4; }
    .nb-subtitle { font-size: 11px; color: #8d8d8d; margin-top: 2px; }
    .nb-header-right { display: flex; align-items: center; gap: 10px; padding: 0 16px; }
    .run-all-btn {
      display: flex; align-items: center; gap: 6px;
      padding: 8px 16px; border-radius: 2px; border: none;
      background: var(--accent-blue); color: white;
      font-family: inherit; font-size: 13px; font-weight: 600;
      cursor: pointer; transition: background 0.15s;
      letter-spacing: 0.01em;
    }
    .run-all-btn:hover { background: #0353e9; }
    .run-all-btn:disabled { background: #4d4d4d; cursor: not-allowed; }

    /* ── LAYOUT ── */
    .nb-body {
      display: grid;
      grid-template-columns: 220px 1fr;
      max-width: 1300px;
      margin: 0 auto;
    }

    /* ── TOC ── */
    .nb-toc {
      position: sticky;
      top: var(--header-h);
      height: calc(100vh - var(--header-h));
      overflow-y: auto;
      background: var(--surface);
      border-right: 1px solid var(--border);
      padding: 20px 0;
    }
    .nb-toc::-webkit-scrollbar { width: 4px; }
    .nb-toc::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
    .toc-section-label {
      font-size: 10px; font-weight: 700; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--text-tertiary);
      padding: 12px 16px 6px;
    }
    .toc-item {
      display: flex; align-items: center; justify-content: space-between;
      padding: 8px 16px; font-size: 13px; color: var(--text-secondary);
      cursor: pointer; border-left: 3px solid transparent;
      transition: all 0.12s; text-decoration: none; gap: 6px;
    }
    .toc-item:hover { background: var(--bg); color: var(--text); }
    .toc-item.active {
      border-left-color: var(--accent-blue);
      background: var(--tag-ex-bg); color: var(--accent-blue); font-weight: 600;
    }
    .toc-badge {
      font-size: 10px; font-weight: 700; padding: 2px 6px;
      border-radius: 20px; white-space: nowrap; flex-shrink: 0;
    }
    .toc-badge.concept { background: var(--tag-concept-bg); color: var(--tag-concept-text); }
    .toc-badge.ex  { background: var(--tag-ex-bg);  color: var(--tag-ex-text);  }
    .toc-badge.pr  { background: var(--tag-pr-bg);  color: var(--tag-pr-text);  }
    .toc-badge.hw  { background: var(--tag-hw-bg);  color: var(--tag-hw-text);  }

    /* ── CONTENT ── */
    .nb-content { padding: 28px 36px 60px; min-width: 0; }

    /* PROGRESS */
    .progress-bar-wrap {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 4px; padding: 14px 20px;
      display: flex; align-items: center; gap: 16px; margin-bottom: 28px;
      box-shadow: var(--shadow-sm);
    }
    .progress-label { font-size: 13px; font-weight: 600; color: var(--text-secondary); white-space: nowrap; }
    .progress-track { flex: 1; height: 6px; background: var(--bg); border-radius: 3px; overflow: hidden; }
    .progress-fill { height: 100%; background: var(--accent-green); border-radius: 3px; transition: width 0.5s cubic-bezier(.4,0,.2,1); }
    .progress-count { font-size: 13px; font-weight: 700; color: var(--accent-green); white-space: nowrap; }

    /* SECTION DIVIDER */
    .sec-divider {
      display: flex; align-items: center; gap: 14px;
      margin: 36px 0 18px;
    }
    .sec-divider:first-of-type { margin-top: 0; }
    .sec-num {
      display: flex; align-items: center; justify-content: center;
      width: 30px; height: 30px; border-radius: 50%;
      font-size: 13px; font-weight: 700; color: white; flex-shrink: 0;
    }
    .sec-num.blue    { background: var(--accent-blue); }
    .sec-num.green   { background: var(--accent-green); }
    .sec-num.red     { background: var(--accent-red); }
    .sec-num.concept { background: #6929c4; }
    .sec-title { font-size: 19px; font-weight: 700; color: var(--text); }
    .sec-divider hr { flex: 1; border: none; border-top: 2px solid var(--border); }

    /* CONCEPT / INFO CELLS */
    .cell-info {
      border-radius: 4px; padding: 16px 20px;
      margin-bottom: 10px; line-height: 1.75;
      border-left: 4px solid;
    }
    .cell-info.concept {
      background: #f6f2ff; border-color: #6929c4;
    }
    .cell-info.tip {
      background: #fff8f0; border-color: var(--accent-orange);
    }
    .cell-info.hint {
      background: var(--out-pass-bg); border-color: var(--accent-green);
    }
    .cell-info.problem {
      background: var(--out-fail-bg); border-color: var(--accent-red);
    }
    .cell-info.example-note {
      background: var(--out-info-bg); border-color: var(--accent-blue);
    }
    .cell-info .info-label {
      font-size: 10px; font-weight: 700; letter-spacing: 0.08em;
      text-transform: uppercase; opacity: 0.65; margin-bottom: 8px;
      display: block;
    }
    .cell-info p { font-size: 14px; margin-bottom: 6px; }
    .cell-info p:last-child { margin-bottom: 0; }
    .cell-info code {
      font-family: 'JetBrains Mono', monospace;
      font-size: 13px; background: rgba(0,0,0,0.07);
      padding: 1px 5px; border-radius: 3px;
    }
    .cell-info pre {
      font-family: 'JetBrains Mono', monospace;
      font-size: 13px; background: rgba(0,0,0,0.05);
      padding: 10px 14px; border-radius: 4px; line-height: 1.7;
      margin-top: 10px; white-space: pre-wrap; overflow-x: auto;
    }
    .cell-info ul { padding-left: 20px; }
    .cell-info li { font-size: 14px; margin-bottom: 5px; }
    .cell-info table { width: 100%; border-collapse: collapse; margin-top: 10px; font-size: 13px; }
    .cell-info th, .cell-info td { padding: 8px 12px; border: 1px solid rgba(0,0,0,0.1); text-align: left; }
    .cell-info th { background: rgba(0,0,0,0.06); font-weight: 700; }

    /* CODE CELLS */
    .cell-code {
      border: 1px solid var(--border);
      border-radius: 4px; overflow: hidden;
      margin-bottom: 12px;
      box-shadow: var(--shadow-sm);
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .cell-code:focus-within {
      border-color: var(--accent-blue);
      box-shadow: 0 0 0 2px rgba(15,98,254,0.15);
    }
    .cell-hdr {
      display: flex; align-items: center; gap: 8px;
      padding: 8px 12px;
      background: var(--surface2); border-bottom: 1px solid var(--border);
    }
    .cell-run {
      width: 26px; height: 26px; border-radius: 50%; border: none;
      background: var(--accent-blue); color: white;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; flex-shrink: 0;
      transition: background 0.12s, transform 0.1s;
    }
    .cell-run:hover { background: #0353e9; transform: scale(1.1); }
    .cell-run:disabled { background: #a8a8a8; transform: none; cursor: not-allowed; }
    .cell-run.running { background: var(--accent-orange); animation: spin 0.8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .cell-exec-count {
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px; color: var(--text-tertiary); min-width: 28px;
    }
    .cell-hdr-label { font-size: 12px; color: var(--text-secondary); flex: 1; }
    .cell-btn {
      display: flex; align-items: center; gap: 4px;
      padding: 4px 11px; border-radius: 2px; border: 1px solid;
      font-family: inherit; font-size: 12px; font-weight: 600;
      cursor: pointer; transition: all 0.12s; white-space: nowrap;
    }
    .cell-btn.check { border-color: var(--accent-green); background: white; color: var(--accent-green); }
    .cell-btn.check:hover { background: var(--out-pass-bg); }
    .cell-btn.reset { border-color: var(--border); background: white; color: var(--text-secondary); }
    .cell-btn.reset:hover { background: var(--bg); }
    .cell-tag {
      font-size: 10px; font-weight: 700; padding: 3px 8px;
      border-radius: 20px; flex-shrink: 0;
    }
    .cell-tag.ex      { background: var(--tag-ex-bg);      color: var(--tag-ex-text); }
    .cell-tag.pr      { background: var(--tag-pr-bg);      color: var(--tag-pr-text); }
    .cell-tag.hw      { background: var(--tag-hw-bg);      color: var(--tag-hw-text); }
    .cell-codelen { font-size: 10px; color: var(--text-tertiary); font-family: 'JetBrains Mono', monospace; }

    .cell-editor {
      width: 100%; min-height: 110px; resize: vertical;
      border: none; outline: none;
      padding: 14px 16px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 13.5px; line-height: 1.7;
      background: var(--editor-bg); color: var(--editor-text);
      tab-size: 4;
    }
    .cell-output { display: none; border-top: 1px solid var(--border); }
    .cell-output.show { display: block; }
    .out-bar {
      display: flex; align-items: center; gap: 8px;
      padding: 7px 14px; font-size: 12px; font-weight: 700;
    }
    .out-bar.info { background: var(--out-info-bg); color: var(--out-info-text); }
    .out-bar.pass { background: var(--out-pass-bg); color: var(--out-pass-text); }
    .out-bar.fail { background: var(--out-fail-bg); color: var(--out-fail-text); }
    .out-text {
      font-family: 'JetBrains Mono', monospace; font-size: 13px;
      padding: 12px 16px; white-space: pre-wrap; line-height: 1.7;
      color: var(--text); background: var(--surface);
    }

    /* SUBMIT */
    .submit-card {
      margin-top: 28px; padding: 24px;
      background: var(--surface); border: 2px solid var(--accent-blue);
      border-radius: 4px; box-shadow: var(--shadow-md);
    }
    .submit-card h3 { font-size: 16px; font-weight: 700; color: var(--accent-blue); margin-bottom: 6px; }
    .submit-checklist {
      background: var(--out-info-bg); border-radius: 4px;
      padding: 12px 16px; margin: 14px 0; font-size: 13px; line-height: 1.8;
    }
    .submit-fields { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; margin-top: 16px; }
    .submit-field { display: flex; align-items: center; gap: 8px; }
    .submit-field label { font-size: 14px; font-weight: 600; }
    .submit-field select {
      padding: 8px 12px; border-radius: 2px;
      border: 1px solid var(--border); font-family: inherit;
      font-size: 14px; outline: none; background: var(--surface);
      cursor: pointer;
    }
    .submit-field select:focus { border-color: var(--accent-blue); }
    .submit-go {
      display: flex; align-items: center; gap: 8px;
      padding: 11px 24px; border-radius: 2px; border: none;
      background: var(--accent-blue); color: white;
      font-family: inherit; font-size: 14px; font-weight: 700;
      cursor: pointer; transition: all 0.15s; letter-spacing: 0.01em;
    }
    .submit-go:hover { background: #0353e9; box-shadow: 0 4px 12px rgba(15,98,254,0.35); }
    .submit-go:disabled { background: #a8a8a8; cursor: not-allowed; box-shadow: none; }
    #submitStatus {
      margin-top: 14px; padding: 12px 16px; border-radius: 4px;
      font-size: 13px; font-family: 'JetBrains Mono', monospace;
      white-space: pre-wrap; line-height: 1.6; display: none;
    }
    #submitStatus.pass { background: var(--out-pass-bg); border-left: 4px solid var(--accent-green); color: var(--out-pass-text); }
    #submitStatus.fail { background: var(--out-fail-bg); border-left: 4px solid var(--accent-red); color: var(--out-fail-text); }
    #submitStatus.warn { background: #fff8f0; border-left: 4px solid var(--accent-orange); color: #8a3800; }

    @media (max-width: 860px) {
      .nb-body { grid-template-columns: 1fr; }
      .nb-toc { display: none; }
      .nb-content { padding: 16px; }
    }
  </style>
</head>
