    .sidebar h3 { font-size: 16px; margin: 22px 0 10px; color: #374151; }
    .sidebar p { line-height: 1.8; margin: 0 0 14px; font-size: 16px; white-space: pre-wrap; }
    .box { margin-top: 10px; background: white; border: 1px solid #d1d5db; border-radius: 12px; padding: 14px; font-family: Consolas, Monaco, monospace; white-space: pre-wrap; line-height: 1.8; font-size: 14px; }
