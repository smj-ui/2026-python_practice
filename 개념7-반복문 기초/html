    .mini { color: #6b7280; font-size: 14px; margin-top: 14px; }
    .main { display: grid; grid-template-rows: auto auto 1fr; min-width: 0; }
    .header-area { background: #1a1f2b; border-bottom: 1px solid #2c3445; padding: 0 20px 12px 20px; }
    .header-row { display: flex; align-items: center; justify-content: space-between; gap: 16px; min-height: 64px; }
    .topbar { padding: 16px 0; font-weight: 700; font-size: 22px; flex: 1; }
    .top-submit-area { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; justify-content: flex-end; }
    .top-submit-title { font-size: 14px; font-weight: 700; color: #f9fafb; margin-right: 4px; white-space: nowrap; }
    .top-submit-row { display: flex; align-items: center; gap: 6px; }
    .top-submit-row label { font-size: 14px; font-weight: 700; color: #e5e7eb; white-space: nowrap; }
    .top-submit-row select { padding: 10px 12px; border-radius: 10px; border: 1px solid #334155; background: #111827; color: #f9fafb; font-size: 14px; outline: none; min-width: 88px; }
    .top-submit-help { color: #cbd5e1; font-size: 13px; line-height: 1.6; white-space: pre-wrap; margin-top: 4px; }
    .tabs-wrap { display: flex; flex-direction: column; gap: 8px; padding: 14px 16px; background: #111827; border-bottom: 1px solid #2c3445; }
    .tabs-row { display: flex; flex-wrap: wrap; gap: 10px; }
    .tab-btn { border: 0; border-radius: 12px; padding: 10px 16px; font-size: 15px; font-weight: 700; cursor: pointer; background: #374151; color: white; }
    .tab-btn.active { background: #7c3aed; }
    .lesson-panel { display: none; }
    .lesson-panel.active { display: block; }
    .editor-wrap { background: #111827; border-bottom: 1px solid #2c3445; }
    .editor-header { display: flex; align-items: center; justify-content: space-between; padding: 12px 16px; background: #2b3242; font-size: 18px; font-weight: 700; }
    .editor { width: 100%; min-height: 320px; resize: vertical; border: 0; outline: none; padding: 18px; background: #000; color: #f9fafb; font-size: 19px; line-height: 1.7; font-family: Consolas, Monaco, monospace; tab-size: 4; }
    .controls { display: flex; flex-wrap: wrap; gap: 12px; padding: 16px; background: #111827; border-top: 1px solid #2c3445; }
    button { border: 0; border-radius: 12px; padding: 12px 18px; font-size: 16px; font-weight: 700; cursor: pointer; }
    .run-btn { background: #ffffff; color: #111827; }
    .check-btn { background: #7c3aed; color: white; }
    .reset-btn { background: #374151; color: white; }
    .submit-btn { background: #10b981; color: white; }
    .panel { border: 1px solid #2c3445; border-radius: 16px; overflow: hidden; background: #111827; margin: 0 16px 16px 16px; }
    .panel-title { padding: 14px 18px; background: #171e2d; border-bottom: 1px solid #2c3445; font-size: 18px; font-weight: 700; }
    .status { padding: 16px 18px 0; font-size: 18px; font-weight: 700; }
    .status.pass { color: #34d399; }
    .status.fail { color: #f87171; }
    .status.info { color: #93c5fd; }
    .log { white-space: pre-wrap; padding: 14px 18px 20px; font-family: Consolas, Monaco, monospace; font-size: 16px; line-height: 1.7; color: #e5e7eb; }
    .hidden { display: none !important; }
